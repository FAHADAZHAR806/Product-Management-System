{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/products/:path*",
      "destination": "/backend/server.js"
    },
    {
      "source": "/api/products",
      "destination": "/backend/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/index.html"
    }
  ]
}
